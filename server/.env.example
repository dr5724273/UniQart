NODE_ENV=development
PORT=5000

# MongoDB connection string (Atlas or local)
# - Atlas (recommended): mongodb+srv://<user>:<password>@<cluster-host>/<db>?retryWrites=true&w=majority
# - Local: mongodb://127.0.0.1:27017/uniqart
# NOTE: If your password has special characters (@ : / ? #), URL-encode it (example: @ -> %40).
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster-host>/uniqart?retryWrites=true&w=majority
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# comma-separated, no trailing slash
CORS_ORIGIN=http://localhost:3000

# where local uploads are stored
UPLOAD_DIR=uploads

